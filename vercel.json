{
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/posts/(.*)", "destination": "/posts/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/posts/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown" }
      ]
    }
  ]
}